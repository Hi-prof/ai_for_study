<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hiprof.core.mapper.ClScoreItemsMapper">
    
    <resultMap type="ClScoreItems" id="ClScoreItemsResult">
        <result property="id"    column="id"    />
        <result property="courseId"    column="course_id"    />
        <result property="itemName"    column="item_name"    />
        <result property="itemType"    column="item_type"    />
        <result property="itemWeight"    column="item_weight"    />
        <result property="maxScore"    column="max_score"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectClScoreItemsVo">
        select id, course_id, item_name, item_type, item_weight, max_score, create_time, update_time from cl_score_items
    </sql>

    <select id="selectClScoreItemsList" parameterType="ClScoreItems" resultMap="ClScoreItemsResult">
        <include refid="selectClScoreItemsVo"/>
        <where>  
            <if test="courseId != null "> and course_id = #{courseId}</if>
            <if test="itemName != null  and itemName != ''"> and item_name like concat('%', #{itemName}, '%')</if>
            <if test="itemType != null  and itemType != ''"> and item_type = #{itemType}</if>
            <if test="itemWeight != null "> and item_weight = #{itemWeight}</if>
        </where>
    </select>
    
    <select id="selectClScoreItemsById" parameterType="Long" resultMap="ClScoreItemsResult">
        <include refid="selectClScoreItemsVo"/>
        where id = #{id}
    </select>

    <insert id="insertClScoreItems" parameterType="ClScoreItems" useGeneratedKeys="true" keyProperty="id">
        insert into cl_score_items
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="courseId != null">course_id,</if>
            <if test="itemName != null and itemName != ''">item_name,</if>
            <if test="itemType != null">item_type,</if>
            <if test="itemWeight != null">item_weight,</if>
            <if test="maxScore != null">max_score,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="courseId != null">#{courseId},</if>
            <if test="itemName != null and itemName != ''">#{itemName},</if>
            <if test="itemType != null">#{itemType},</if>
            <if test="itemWeight != null">#{itemWeight},</if>
            <if test="maxScore != null">#{maxScore},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateClScoreItems" parameterType="ClScoreItems">
        update cl_score_items
        <trim prefix="SET" suffixOverrides=",">
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="itemName != null and itemName != ''">item_name = #{itemName},</if>
            <if test="itemType != null">item_type = #{itemType},</if>
            <if test="itemWeight != null">item_weight = #{itemWeight},</if>
            <if test="maxScore != null">max_score = #{maxScore},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteClScoreItemsById" parameterType="Long">
        delete from cl_score_items where id = #{id}
    </delete>

    <delete id="deleteClScoreItemsByIds" parameterType="String">
        delete from cl_score_items where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>