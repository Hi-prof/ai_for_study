<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hiprof.core.mapper.ZstpNodeMapper">
    
    <resultMap type="ZstpNode" id="ZstpNodeResult">
        <result property="id"    column="id"    />
        <result property="parentId"    column="parent_id"    />
        <result property="graphId"    column="graph_id"    />
        <result property="name"    column="name"    />
        <result property="content"    column="content"    />
    </resultMap>

    <sql id="selectZstpNodeVo">
        select id, parent_id, graph_id, name, content from zstp_node
    </sql>

    <select id="selectZstpNodeList" parameterType="ZstpNode" resultMap="ZstpNodeResult">
        <include refid="selectZstpNodeVo"/>
        <where>  
            <if test="parentId != null "> and parent_id = #{parentId}</if>
            <if test="graphId != null "> and graph_id = #{graphId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>
    
    <select id="selectZstpNodeById" parameterType="Long" resultMap="ZstpNodeResult">
        WITH RECURSIVE tree_cte AS (
        -- 查询根节点
        SELECT id,parent_id,graph_id,name,content FROM zstp_node WHERE id = #{id}
        UNION ALL
        -- 递归查询子节点
        SELECT n.id, n.parent_id,n.graph_id,n.name,n.content
        FROM zstp_node n
        INNER JOIN tree_cte c ON n.parent_id = c.id
        )SELECT * FROM tree_cte
    </select>

    <select id="selectZstpNodeByGraphIds"  resultMap="ZstpNodeResult">
        select * from zstp_node where graph_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insertZstpNode" parameterType="ZstpNode"  useGeneratedKeys="true" keyProperty="id">
        insert into zstp_node
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="parentId != null">parent_id,</if>
            <if test="graphId != null">graph_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="content != null">content,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="parentId != null">#{parentId},</if>
            <if test="graphId != null">#{graphId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="content != null">#{content},</if>
         </trim>
    </insert>

    <update id="updateZstpNode" parameterType="ZstpNode">
        update zstp_node
        <trim prefix="SET" suffixOverrides=",">
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="graphId != null">graph_id = #{graphId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="content != null">content = #{content},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteZstpNodeById" parameterType="Long">
        delete from zstp_node where id = #{id}
    </delete>

    <delete id="deleteZstpNodeByIds" >
        delete from zstp_node where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectZstpNodeListByParentIds" resultMap="ZstpNodeResult" >
        select * from zstp_node where parent_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>