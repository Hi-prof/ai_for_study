<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hiprof.core.mapper.ClWorkMapper">
    
    <resultMap type="ClWork" id="ClWorkResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="tFile"    column="t_file"    />
        <result property="tContent"    column="t_content"    />
        <result property="sFile"    column="s_file"    />
        <result property="sContent"    column="s_content"    />
        <result property="courseId"    column="course_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="overTime"    column="over_time"    />

    </resultMap>

    <sql id="selectClWorkVo">
        select id, name, t_file, t_content, s_file, s_content, course_id, create_time, update_time,over_time from cl_work
    </sql>

    <select id="selectClWorkList" parameterType="ClWork" resultMap="ClWorkResult">
        <include refid="selectClWorkVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="courseId != null "> and course_id = #{courseId}</if>
        </where>
    </select>
    
    <select id="selectClWorkById" parameterType="Long" resultMap="ClWorkResult">
        <include refid="selectClWorkVo"/>
        where id = #{id}
    </select>

    <insert id="insertClWork" parameterType="ClWork" useGeneratedKeys="true" keyProperty="id">
        insert into cl_work
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name,</if>
            <if test="tFile != null">t_file,</if>
            <if test="tContent != null">t_content,</if>
            <if test="sFile != null">s_file,</if>
            <if test="sContent != null">s_content,</if>
            <if test="courseId != null">course_id,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="overTime != null">over_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="tFile != null">#{tFile},</if>
            <if test="tContent != null">#{tContent},</if>
            <if test="sFile != null">#{sFile},</if>
            <if test="sContent != null">#{sContent},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="overTime != null">#{overTime},</if>
         </trim>
    </insert>

    <update id="updateClWork" parameterType="ClWork">
        update cl_work
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="tFile != null">t_file = #{tFile},</if>
            <if test="tContent != null">t_content = #{tContent},</if>
            <if test="sFile != null">s_file = #{sFile},</if>
            <if test="sContent != null">s_content = #{sContent},</if>
            <if test="courseId != null">course_id = #{courseId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="overTime != null">over_time = #{overTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteClWorkById" parameterType="Long">
        delete from cl_work where id = #{id}
    </delete>

    <delete id="deleteClWorkByIds" parameterType="String">
        delete from cl_work where id in 
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteClWorkByCourseIds" parameterType="String">
        delete from cl_work where course_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>