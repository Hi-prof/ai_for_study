<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hiprof.core.mapper.ZstpLineMapper">
    
    <resultMap type="ZstpLine" id="ZstpLineResult">
        <result property="id"    column="id"    />
        <result property="nodeId"    column="node_id"    />
        <result property="targetId"    column="target_id"    />
        <result property="content"    column="content"    />
    </resultMap>

    <sql id="selectZstpLineVo">
        select id, node_id, target_id, content from zstp_line
    </sql>

    <select id="selectZstpLineList" parameterType="ZstpLine" resultMap="ZstpLineResult">
        <include refid="selectZstpLineVo"/>
        <where>  
            <if test="nodeId != null "> and node_id = #{nodeId}</if>
            <if test="targetId != null "> and target_id = #{targetId}</if>
        </where>
    </select>
    
    <select id="selectZstpLineById" parameterType="Long" resultMap="ZstpLineResult">
        <include refid="selectZstpLineVo"/>
        where id = #{id}
    </select>

    <insert id="insertZstpLine" parameterType="ZstpLine" useGeneratedKeys="true" keyProperty="id">
        insert into zstp_line
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="nodeId != null">node_id,</if>
            <if test="targetId != null">target_id,</if>
            <if test="content != null">content,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="nodeId != null">#{nodeId},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="content != null">#{content},</if>
         </trim>
    </insert>

    <update id="updateZstpLine" parameterType="ZstpLine">
        update zstp_line
        <trim prefix="SET" suffixOverrides=",">
            <if test="nodeId != null">node_id = #{nodeId},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="content != null">content = #{content},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteZstpLineById" parameterType="Long">
        delete from zstp_line where id = #{id}
    </delete>

    <delete id="deleteZstpLineByIds" parameterType="String">
        delete from zstp_line where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteZstpLineByNodeIds" parameterType="String">
        delete from zstp_line where node_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>