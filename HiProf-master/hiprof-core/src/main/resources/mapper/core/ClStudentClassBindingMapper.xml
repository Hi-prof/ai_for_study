<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hiprof.core.mapper.ClStudentClassBindingMapper">

    <resultMap type="ClStudentClassBinding" id="ClStudentClassBindingResult">
        <result property="id"         column="id" />
        <result property="studentId"  column="student_id" />
        <result property="majorId"    column="major_id" />
        <result property="className"  column="class_name" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectClStudentClassBindingVo">
        select id, student_id, major_id, class_name, create_time, update_time
        from cl_student_class_binding
    </sql>

    <select id="selectClStudentClassBindingByStudentId" parameterType="Long" resultMap="ClStudentClassBindingResult">
        <include refid="selectClStudentClassBindingVo" />
        where student_id = #{studentId}
        limit 1
    </select>

    <select id="selectClStudentClassBindingList" parameterType="ClStudentClassBinding" resultMap="ClStudentClassBindingResult">
        <include refid="selectClStudentClassBindingVo" />
        <where>
            <if test="studentId != null">and student_id = #{studentId}</if>
            <if test="majorId != null">and major_id = #{majorId}</if>
            <if test="className != null and className != ''">and class_name = #{className}</if>
        </where>
    </select>

    <insert id="insertClStudentClassBinding" parameterType="ClStudentClassBinding" useGeneratedKeys="true" keyProperty="id">
        insert into cl_student_class_binding
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="majorId != null">major_id,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="majorId != null">#{majorId},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateClStudentClassBinding" parameterType="ClStudentClassBinding">
        update cl_student_class_binding
        <trim prefix="SET" suffixOverrides=",">
            <if test="majorId != null">major_id = #{majorId},</if>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where student_id = #{studentId}
    </update>

    <delete id="deleteClStudentClassBindingByStudentId" parameterType="Long">
        delete from cl_student_class_binding where student_id = #{studentId}
    </delete>

    <delete id="deleteClStudentClassBindingByStudentIds" parameterType="Long">
        delete from cl_student_class_binding where student_id in
        <foreach collection="array" item="studentId" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>
</mapper>
